<?xml version="1.0" encoding="utf-8"?>
<!--
    HomeActivity layout — the real adaptive launcher home screen.
    Structure:
      - Adapto logo + title at the very top (matches main8 branding)
      - SearchView below the header
      - RecyclerView (app grid) fills the middle
      - Bottom dock with the same 6 quick-access icons from MainActivity8
      - FAB bottom-right corner opens accessibility settings (MainActivity4)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home">

    <!-- Adapto logo — same drawable as main8 -->
    <ImageView
        android:id="@+id/home_logo"
        android:layout_width="120dp"
        android:layout_height="80dp"
        android:layout_marginTop="16dp"
        app:srcCompat="@drawable/img_11"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- App name -->
    <TextView
        android:id="@+id/home_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Adapto"
        android:textColor="#F7960DC7"
        android:textSize="28sp"
        app:layout_constraintTop_toBottomOf="@id/home_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Search bar -->
    <SearchView
        android:id="@+id/search_view"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp"
        android:iconifiedByDefault="false"
        android:queryHint="Search apps…"
        android:background="#CC1A1A2E"
        app:layout_constraintTop_toBottomOf="@id/home_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <!-- TTS Speak Button -->
    <Button
        android:id="@+id/btn_speak"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="12dp"
        android:text="🔊 Read Screen"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:backgroundTint="#2563EB"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:contentDescription="Read screen content aloud"
        app:layout_constraintTop_toBottomOf="@id/search_view"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- App grid fills everything between search and dock -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_apps"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/btn_speak"
        app:layout_constraintBottom_toTopOf="@id/dock_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom dock — exact same icons and drawables as MainActivity8 -->
    <LinearLayout
        android:id="@+id/dock_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:background="#CC1A1A2E"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Gallery (images_removebg_preview__4_) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:id="@+id/dock_gallery"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="Gallery"
                app:srcCompat="@drawable/images_removebg_preview__4_" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Gallery" android:textColor="#FFFFFF" android:textSize="10sp" />
        </LinearLayout>

        <!-- Phone (images_removebg_preview__3_) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:id="@+id/dock_phone"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="Phone"
                app:srcCompat="@drawable/images_removebg_preview__3_" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Phone" android:textColor="#FFFFFF" android:textSize="10sp" />
        </LinearLayout>

        <!-- Camera (download__5__removebg_preview) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:id="@+id/dock_camera"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="Camera"
                app:srcCompat="@drawable/download__5__removebg_preview" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Camera" android:textColor="#FFFFFF" android:textSize="10sp" />
        </LinearLayout>

        <!-- Contacts (images__1__removebg_preview__1_) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:id="@+id/dock_contacts"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="Contacts"
                app:srcCompat="@drawable/images__1__removebg_preview__1_" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Contacts" android:textColor="#FFFFFF" android:textSize="10sp" />
        </LinearLayout>

        <!-- SOS (images__1__removebg_preview) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:id="@+id/dock_sos"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="SOS"
                app:srcCompat="@drawable/images__1__removebg_preview" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SOS" android:textColor="#FF4444" android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Voice (images_removebg_preview) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:id="@+id/dock_voice"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="Voice"
                app:srcCompat="@drawable/images_removebg_preview" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Voice" android:textColor="#FFFFFF" android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- FAB → Accessibility Settings -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="96dp"
        android:contentDescription="Accessibility Settings"
        app:srcCompat="@android:drawable/ic_menu_manage"
        app:tint="#FFFFFF"
        app:backgroundTint="#2563EB"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
