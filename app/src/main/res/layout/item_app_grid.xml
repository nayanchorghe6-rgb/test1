<?xml version="1.0" encoding="utf-8"?>
<!--
    Single cell in the home screen app grid.
    Icon size (iv_app_icon) and label text size (tv_app_label)
    are both set programmatically by AppGridAdapter based on
    the current AccessibilityPreferences values.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="8dp"
    android:background="?attr/selectableItemBackgroundBorderless">

    <ImageView
        android:id="@+id/iv_app_icon"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:scaleType="fitCenter"
        android:contentDescription="" />

    <TextView
        android:id="@+id/tv_app_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:textSize="14sp"
        android:textColor="#FFFFFF" />

</LinearLayout>
